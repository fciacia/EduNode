# ── EduNode configuration ─────────────────────────────────────────────────────
# Copy this file to .env and edit before running.

# Ollama endpoint (default: local)
OLLAMA_BASE=http://127.0.0.1:11434

# Model to use — must be pulled with `ollama pull <model>`
OLLAMA_MODEL=phi3:mini
# Alternatives:
#   OLLAMA_MODEL=gemma2:2b-instruct-q4_K_M
#   OLLAMA_MODEL=phi3:mini-4k-instruct-q4_K_M

# Sentence-transformer embedding model (downloaded automatically on first run)
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# RAG settings
CHUNK_SIZE=400
CHUNK_OVERLAP=60
TOP_K=5
MAX_TOKENS=512

# Flask server
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# Max document upload size in MB
MAX_UPLOAD_MB=32

# Admin token — CHANGE THIS before deploying on a school network!
ADMIN_TOKEN=change-me-in-dot-env
